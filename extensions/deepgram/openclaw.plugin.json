{
  "id": "deepgram",
  "icon": "https://cdn.simpleicons.org/deepgram/111111",
  "activation": {
    "onStartup": false
  },
  "enabledByDefault": true,
  "setup": {
    "providers": [
      {
        "id": "deepgram",
        "envVars": ["DEEPGRAM_API_KEY"]
      }
    ]
  },
  "contracts": {
    "mediaUnderstandingProviders": ["deepgram"],
    "realtimeTranscriptionProviders": ["deepgram"]
  },
  "mediaUnderstandingProviderMetadata": {
    "deepgram": {
      "capabilities": ["audio"],
      "defaultModels": {
        "audio": "nova-3"
      },
      "autoPriority": {
        "audio": 30
      }
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  }
}
